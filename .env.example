# --- Models ----------------------------------------------------------------
# LLM: mock (default, no key) | anthropic | openai
VERITAS_LLM=mock
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
VERITAS_EMBEDDINGS=hashing       # hashing (default) | openai
VERITAS_EMBED_DIM=256

# --- Vector store ----------------------------------------------------------
# memory (default) | qdrant | pinecone
VERITAS_VECTOR=memory
QDRANT_URL=http://localhost:6333
PINECONE_INDEX=veritas

# --- Chunking / retrieval --------------------------------------------------
VERITAS_CHUNK_TOKENS=180
VERITAS_CHUNK_OVERLAP=40
VERITAS_CONTEXTUAL=true
VERITAS_TOP_K=6
VERITAS_RRF_K=60
VERITAS_CANDIDATE_K=20

# --- Grounding (anti-hallucination) ---------------------------------------
VERITAS_MIN_OVERLAP=0.12
